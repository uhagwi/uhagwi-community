# ============================================================
# 우하귀 Discord 봇 환경변수 예시
# 복사: cp env.example .env   (파일명 앞에 점(.) 붙이기)
# 실제 .env 파일은 git 에 올리지 않습니다.
# ============================================================

# --- Discord 자격증명 ---
# 봇 토큰 (절대 유출 금지, Discord Developer Portal → Bot 탭)
DISCORD_BOT_TOKEN=your-bot-token-here
# 봇 Application(Client) ID
DISCORD_CLIENT_ID=000000000000000000
# 길드(서버) ID — 개발/테스트용 커맨드 즉시 등록에 사용 (운영 글로벌 배포 시 비움)
DISCORD_GUILD_ID=000000000000000000

# --- 웹 연동 ---
# 웹 서버 베이스 URL (봇 → 웹 이벤트 POST 대상)
WEB_BASE_URL=http://localhost:3000
# HMAC 공유 시크릿 (웹·봇 동일값, 절대 유출 금지)
# 봇→웹 요청 시 X-Bot-Signature 헤더 서명에 사용
DISCORD_BOT_WEBHOOK_SECRET=change-me-to-a-long-random-hex-string

# --- 런타임 옵션 ---
# 로그 레벨 (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info
# 실행 환경 (development|production)
NODE_ENV=development
